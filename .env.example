# Copy to .env.local (gitignored) and fill in real values.
# Keep secrets server-side — never use a NEXT_PUBLIC_ prefix for them.

# --- Application ---
# Signs the member session cookie (HMAC). Generate: openssl rand -hex 32
SESSION_SECRET=
# Canonical site URL for Auth and OAuth redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Set to "maintenance" to show the maintenance page.
SITE_MODE=

# --- Supabase ---
# From Supabase: Project Settings -> API. Run supabase/schema.sql first.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Bypasses Row Level Security; server-side only. Treat like a password.
SUPABASE_SERVICE_ROLE_KEY=

# --- Apple Wallet (base64-encoded PEM) ---
# See README "Apple Wallet". Base64-encode each cert/key before setting.
APPLE_SIGNER_CERT=
APPLE_SIGNER_KEY=
APPLE_SIGNER_KEY_PASSPHRASE=
APPLE_WWDR_CERT=
