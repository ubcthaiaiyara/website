# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. NONE of these are NEXT_PUBLIC_-prefixed: they are
# server-only secrets and must never reach the client bundle.
#
# With NO vars set, the app still runs: members are stored in memory and the
# pass endpoint will error only when you try to download a pass (no certs). Set
# the Supabase vars to persist members; set the Apple vars to sign real passes.

# --- Sessions ---------------------------------------------------------------
# Secret used to sign the member session cookie (HMAC). Any long random string.
# Generate one with: openssl rand -hex 32
# If unset, a dev fallback is used so the app still runs — but you MUST set a
# real value in production, or sessions can be forged.
SESSION_SECRET=

# --- Supabase ---------------------------------------------------------------
# Project URL (base URL only, no /rest/v1 suffix) and the SERVICE ROLE key.
# Find both in the Supabase dashboard: Project Settings -> API.
# Run supabase/schema.sql first to create the table.
#
# The service role key bypasses Row Level Security. It is safe here ONLY because
# this app reads it server-side (never NEXT_PUBLIC_-prefixed) and never sends it
# to the browser. Treat it like a password: keep it out of logs, client code,
# and version control.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Apple Wallet certificates (all base64-encoded) -------------------------
# Each value is the base64 encoding of a PEM/text file. See the README section
# "Apple Wallet setup" for how to create and export each one, then base64 them.

# Your Pass Type ID signing certificate, as PEM. Exported from the .p12.
APPLE_SIGNER_CERT=

# The private key that pairs with the signer cert, as PEM. Exported from the .p12.
APPLE_SIGNER_KEY=

# The passphrase protecting the private key (the one you set during .p12 export).
APPLE_SIGNER_KEY_PASSPHRASE=

# Apple Worldwide Developer Relations (WWDR) intermediate certificate, as PEM.
# Downloaded from Apple (see README).
APPLE_WWDR_CERT=
